# URL base completa da API UNO (inclui o segmento, ex.: granlave-api).
# Quando definida, tem prioridade sobre a auto-detecção pelo iframe.
VITE_UNO_API_BASE_URL=https://prata14.unoerp.com.br/granlave-api/

# (Opcional) Apenas o segmento do path, usado quando a base é derivada
# do referrer do iframe pai. Default: unoerp-api.
# A heurística *-web → *-api já cobre granlave-web/granlave-api automaticamente.
# VITE_UNO_API_PATH=granlave-api